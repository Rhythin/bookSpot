# Root env file for reference

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable

# JWT (Shared secret for all services)
JWT_SECRET=your_super_secret_key_change_this_in_production

# OpenTelemetry (Shared OTLP endpoint)
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4318
